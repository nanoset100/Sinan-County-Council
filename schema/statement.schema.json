{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sinan-council.local/schema/statement.schema.json",
  "title": "statement",
  "description": "발언 (PRD v0.4 §8) — A2가 생성, 검수 후 게시. text 는 발언 단위 전체(임의 절삭 금지).",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "meeting_id", "member_id", "kind", "text", "anchor", "_meta"],
  "properties": {
    "id": { "type": "string", "pattern": "^stmt-[0-9]{4}$" },
    "meeting_id": { "type": "string" },
    "member_id": { "type": "string" },
    "kind": { "type": "string", "enum": ["5분자유발언", "시정질문", "안건토론", "기타"] },
    "text": { "type": "string", "description": "발언 단위 전체(임의 절삭 금지)" },
    "anchor": { "$ref": "anchor.schema.json" },
    "region_tags": { "type": "array", "items": { "type": "string" } },
    "ai_content": { "$ref": "ai_content.schema.json" },
    "_meta": { "$ref": "_meta.schema.json" }
  }
}
