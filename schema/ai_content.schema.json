{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sinan-council.local/schema/ai_content.schema.json",
  "title": "ai_content",
  "description": "AI 생성 콘텐츠 공통 블록 (PRD v0.4 §8, §14-4). 어떤 레코드든 AI 생성물은 반드시 이 블록 안에만 존재(원본 필드와 물리적 분리). 게시되려면 verifier_passed=true 이고 reviewed_by 가 채워져야 한다(실질 게이트=사람 검수, §14-3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["generated_at", "model", "verifier_passed", "summary_one_line"],
  "properties": {
    "generated_at": { "type": "string", "format": "date" },
    "model": {
      "type": "string",
      "description": "사용 모델 식별자 (AI 투명성 페이지 §14-5 와 일치)"
    },
    "verifier_passed": {
      "type": "boolean",
      "description": "§6-④ 스크리닝 통과 여부. 정확성 증명이 아님(§6 한계)."
    },
    "reviewed_by": {
      "type": ["string", "null"],
      "description": "AI 초안 검수자 ID — 실질 게이트. null=미검수(게시 불가)."
    },
    "reviewed_at": { "type": ["string", "null"], "format": "date" },
    "summary_one_line": {
      "type": "string",
      "description": "A1 ⓐ 한 줄 요지"
    },
    "what_changes": {
      "type": "array",
      "description": "A1 ⓑ 무엇이 어떻게 바뀌나 — 문단별 text + 원문 앵커",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "anchor"],
        "properties": {
          "text": { "type": "string" },
          "anchor": { "$ref": "anchor.schema.json" }
        }
      }
    },
    "who_affected": {
      "type": "object",
      "description": "A1 ⓒ 누구에게 적용되나 — 적용 대상·시행일만",
      "additionalProperties": false,
      "required": ["text", "anchor"],
      "properties": {
        "text": { "type": "string" },
        "anchor": { "$ref": "anchor.schema.json" }
      }
    }
  }
}
