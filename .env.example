# 신안군 의정활동 공개 포털 — 환경변수 예시
# 실제 값을 채운 사본을 .env 로 저장하세요. .env 는 커밋 금지(.gitignore).

# --- S1: 국회도서관 지방의정포털 Open API (§4, §12-G0) ---
# 인증키 발급: 포털 로그인 후 리소스센터 신청 또는 lawstat@nanet.go.kr 메일 신청(영업일 7일 내 회신).
# 자세한 절차는 docs/G0-api-key-request.md 참조.
S1_API_KEY=
# 신안군의회 rasmblyId — 지방의회 코드값(예: 06xxxx 형태의 6자리). 사람이 읽는 이름 아님.
# 리소스센터 > Open API > 요청변수의 rasmblyId "목록 보기"에서 "신안군"을 찾아 코드를 넣는다.
S1_RASMBLY_ID=

# 수집기 어댑터 선택: s1 | manual  (기본 manual — G0 통과 전 폴백)
COLLECTOR=manual

# --- AI Drafter (A1 등, §7-B) ---
# 배치 1에서는 인터페이스/드라이런만. 실제 배치 생성은 배치 2.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
