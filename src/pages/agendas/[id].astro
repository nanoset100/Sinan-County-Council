---
import Layout from "../../components/Layout.astro";
import AiSummary from "../../components/AiSummary.astro";
import Timeline from "../../components/Timeline.astro";
import SourceMeta from "../../components/SourceMeta.astro";
import { annotateGlossary } from "../../lib/glossary";
import { getAgendas, getMember, getMeeting } from "../../lib/content";

export function getStaticPaths() {
  return getAgendas().map((a) => ({ params: { id: a.id }, props: { agenda: a } }));
}
const { agenda } = Astro.props;
const members = (agenda.related_members ?? []).map((id) => getMember(id)).filter(Boolean);
const meetings = (agenda.related_meetings ?? []).map((id) => getMeeting(id)).filter(Boolean);
---
<Layout title={`${agenda.title} — 안건`}>
  <p class="muted"><a href="/agendas">← 안건 목록</a></p>
  <div class="row" style="justify-content:space-between">
    <h1 style="margin-bottom:0.25rem">{agenda.title}</h1>
    {agenda.isSample && <span class="badge">샘플</span>}
  </div>
  <div class="row muted" style="gap:0.75rem">
    <span class="badge">{agenda.type}</span>
    {agenda.bill_no && <span>의안번호 {agenda.bill_no}</span>}
    <span>제안 {agenda.proposer.raw} ({agenda.proposer.type})</span>
  </div>

  <!-- AI 요약 블록 상단 배치 (§7-A F4) -->
  <AiSummary ai={agenda.ai_content} sourceText={agenda.outline} sourceUrl={agenda._meta.source_url} />

  <h2>의안요지 (원문)</h2>
  <p class="card" set:html={annotateGlossary(agenda.outline)} />

  <h2>진행 타임라인</h2>
  <Timeline timeline={agenda.timeline} />

  <h2>표결</h2>
  <p class="muted">{agenda.votes.recorded ? "표결 기록 있음" : "개별 표결 기록 없음(기록상 무기명 처리)"}</p>

  {(members.length > 0 || meetings.length > 0 || agenda.related_dept) && (
    <>
      <h2>관련</h2>
      <ul class="stack" style="list-style:none;padding:0">
        {members.map((m) => <li><a href={`/members/${m!.id}`}>👤 {m!.name}</a></li>)}
        {meetings.map((m) => <li><a href="/meetings">📄 {m!.session ?? ""} {m!.type} ({m!.date})</a></li>)}
        {agenda.related_dept && <li>🏛 소관 부서: {agenda.related_dept}</li>}
      </ul>
    </>
  )}

  {agenda.region_tags && agenda.region_tags.length > 0 && (
    <p class="row" style="margin-top:1rem">읍면·섬: {agenda.region_tags.map((r) => <span class="badge">{r}</span>)}</p>
  )}

  <hr style="margin:1.5rem 0;border:none;border-top:1px solid var(--c-border)" />
  <SourceMeta meta={agenda._meta} label="안건 원문 보기" />
</Layout>
