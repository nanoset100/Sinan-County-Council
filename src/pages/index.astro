---
import Layout from "../components/Layout.astro";
import { getAgendas, getMeetings, getMembers, getExecutives, firstDate } from "../lib/content";

const agendas = getAgendas();
const meetings = getMeetings();
const members = getMembers();
const executives = getExecutives();

type Item = { date: string; kind: string; title: string; href: string };
const recent: Item[] = [
  ...agendas.map((a) => ({ date: firstDate(a), kind: "안건", title: a.title, href: `/agendas/${a.id}` })),
  ...meetings.map((m) => ({ date: m.date, kind: "회의록", title: `${m.session ?? ""} ${m.type}`.trim(), href: `/meetings` })),
  ...executives.map((e) => ({ date: e.date, kind: "집행부", title: e.title, href: `/executive` })),
].sort((a, b) => (b.date ?? "").localeCompare(a.date ?? "")).slice(0, 10);

const lastUpdated = recent[0]?.date ?? "-";
---
<Layout>
  <h1>신안군 의정활동, 읽기 쉽게.</h1>
  <p class="muted">판단은 군민이, 번역은 AI가. 공개된 공식 기록을 한곳에 모아 출처와 함께 공개합니다.</p>

  <form action="/search" method="get" class="row" style="margin:1rem 0" role="search">
    <label for="q" class="visually-hidden">검색어</label>
    <input id="q" name="q" type="search" placeholder="안건·의원·키워드 검색"
      style="flex:1;min-width:12rem;padding:0.6rem;border:1px solid var(--c-border);border-radius:var(--radius)" />
    <button type="submit" class="badge" style="padding:0.6rem 1rem">검색</button>
  </form>

  <section class="row" style="gap:1rem;margin:1rem 0">
    <div class="card"><strong>{agendas.length}</strong><div class="muted">등록 안건</div></div>
    <div class="card"><strong>{meetings.length}</strong><div class="muted">회의록</div></div>
    <div class="card"><strong>{members.length}</strong><div class="muted">의원</div></div>
    <div class="card"><strong>{lastUpdated}</strong><div class="muted">최근 갱신</div></div>
  </section>

  <h2>최근 기록</h2>
  {recent.length === 0 ? (
    <p class="muted">아직 게시된 기록이 없습니다.</p>
  ) : (
    <ul class="stack" style="list-style:none;padding:0">
      {recent.map((r) => (
        <li class="card">
          <div class="row" style="justify-content:space-between">
            <a href={r.href} style="font-weight:600">{r.title}</a>
            <span class="badge">{r.kind}</span>
          </div>
          <div class="muted">{r.date}</div>
        </li>
      ))}
    </ul>
  )}
</Layout>
