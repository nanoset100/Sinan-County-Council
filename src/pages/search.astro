---
import Layout from "../components/Layout.astro";
---
<Layout title="검색 — 신안군 의정활동 공개 포털">
  <h1>검색</h1>
  <p class="muted">수록된 안건을 전문 검색합니다. 오른쪽 필터로 <strong>유형·연도·읍면·의원</strong>을 걸 수 있습니다.</p>

  <div id="search" style="margin-top:1rem"></div>
  <p id="search-fallback" class="banner-warn">
    검색 색인은 정적 빌드 시 생성됩니다(<code>npm run build</code> → Pagefind). 개발 서버에서는 동작하지 않을 수 있습니다.
  </p>

  <link is:inline rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <!-- 클래식 스크립트는 문서 순서대로 실행되므로, 외부 스크립트 다음 인라인에서 바로 초기화한다. -->
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    (function () {
      if (typeof PagefindUI === "undefined") return;
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
        translations: { placeholder: "안건 검색", zero_results: "결과가 없습니다: [SEARCH_TERM]" },
      });
      var fb = document.getElementById("search-fallback");
      if (fb) fb.style.display = "none";
      var q = new URLSearchParams(location.search).get("q");
      if (q) {
        setTimeout(function () {
          var input = document.querySelector(".pagefind-ui__search-input");
          if (input) { input.value = q; input.dispatchEvent(new Event("input", { bubbles: true })); }
        }, 50);
      }
    })();
  </script>
</Layout>
