{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pipeline/*": ["pipeline/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": ["src", "pipeline", "scripts", "config", "*.ts", "*.mjs"],
  "exclude": ["node_modules", "dist"]
}
